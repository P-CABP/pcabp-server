<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pcabp.core.user.repository.UserRepository">

    <resultMap id="findUserWithAuthority"
               type="com.pcabp.core.user.vo.User">
        <id property="username" column="USERNAME" />
        <collection property="authorities"
                    ofType="string">
            <result column="AUTHORITY" />
        </collection>
    </resultMap>

    <select id="findUser"
            parameterType="com.pcabp.core.user.dto.UserSearchParam"
            resultMap="findUserWithAuthority">
        SELECT U.USERNAME
             , U.PASSWORD
             , UA.AUTHORITY
          FROM TB_USER U
          LEFT JOIN TB_USER_AUTHORITY UA
                 ON U.USERNAME = UA.USERNAME
         WHERE TRUE
        <if test="username != null and username != ''">
           AND U.USERNAME = #{username}
        </if>
    </select>

</mapper>